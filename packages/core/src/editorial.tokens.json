  "hierarchy": {
    "scale": "perfect-fourth",
    "baseSize": "1.125rem",
    "headings": {
      "h1": {
        "fontFamily": ["Georgia", "Iowan Old Style", "serif"],
        "fontSize": "4.7348rem",
