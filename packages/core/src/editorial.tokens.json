      },
      "h2": {
        "fontFamily": ["Georgia", "Iowan Old Style", "serif"],
        "fontSize": "3.552rem",
        "fontWeight": 700,
        "lineHeight": 1.08,
        "letterSpacing": "-0.02em"
      },
      "h3": {
        "fontFamily": ["Georgia", "Iowan Old Style", "serif"],
        "fontSize": "2.6647rem",
        "fontWeight": 650,
        "lineHeight": 1.12,
        "letterSpacing": "-0.02em"
      },
      "h4": {
        "fontFamily": ["Georgia", "Iowan Old Style", "serif"],
        "fontSize": "1.999rem",
