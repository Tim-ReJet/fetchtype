        "hierarchy.headings.h1.letterSpacing": "-0.04em",
        "hierarchy.headings.h2.lineHeight": 0.98,
        "hierarchy.headings.h2.letterSpacing": "-0.03em"
      }
    },
    "interface": {
      "name": "interface",
      "description": "Compact typography for application UI",
      "tokens": {
        "typography.heading.fontFamily": ["Inter", "system-ui", "sans-serif"],
        "typography.heading.lineHeight": 1.1,
